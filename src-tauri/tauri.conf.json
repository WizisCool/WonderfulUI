{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WonderfulUI",
  "version": "0.1.4",
  "identifier": "app.local.wonderfului",
  "build": {
    "frontendDist": "../packages/gui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run --cwd packages/gui dev",
    "beforeBuildCommand": "bun run --cwd packages/gui build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "WonderfulUI",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**",
          "$LOCALDATA/wonderful-ui/assets/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": [
          "SimpChinese"
        ],
        "displayLanguageSelector": false,
        "installMode": "perMachine",
        "template": "installer.nsi",
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": false,
      "dialog": false,
      "endpoints": [],
      "pubkey": ""
    }
  }
}
