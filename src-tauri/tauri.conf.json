{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WonderfulUI",
  "version": "0.1.8",
  "identifier": "app.local.wonderfului",
  "build": {
    "frontendDist": "../packages/gui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run --cwd packages/gui dev",
    "beforeBuildCommand": "bun run --cwd packages/gui build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "WonderfulUI",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "center": true,
        "devtools": true,
        "additionalBrowserArgs": "--force-prefers-no-reduced-motion"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**",
          "$LOCALDATA/wonderful-ui/assets/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": [
          "SimpChinese"
        ],
        "displayLanguageSelector": false,
        "installMode": "perMachine",
        "template": "installer.nsi",
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/WizisCool/WonderfulUI/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU5QUE4MDY2ODg0NjI0OTQKUldTVUpFYUlab0NxNmZqcEg3RmdodkFLQXN5RmpEcHBvSGFrcStBUFpnZFg5SmF1b3Z6dThkUUQK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
